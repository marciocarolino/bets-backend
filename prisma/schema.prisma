// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  //  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model user {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model competition {
  id        String   @id @default(uuid())
  name      String
  slug      String
  country   String
  season    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  games     Game[]

  @@unique([slug, season])
}

model Team {
  id        String   @id @default(uuid())
  name      String
  alias     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  homeGames Game[]   @relation("teamA")
  awayGames Game[]   @relation("teamB")
}

model Game {
  id            String      @id @default(uuid())
  teamAId       String
  teamBId       String
  competitionId String
  scheduledAt   DateTime?
  isTBD         Boolean     @default(true)
  status        String      @default("UNDEFINED")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  teamA         Team        @relation("teamA", fields: [teamAId], references: [id])
  teamB         Team        @relation("teamB", fields: [teamBId], references: [id])
  competition   competition @relation(fields: [competitionId], references: [id])
}

enum SagaContextStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  COMPENSATING
  COMPENSATED
}

model SagaContext {
  id            String            @id @default(uuid())
  sagaName      String
  externalId    String?
  rawDataHash   String
  status        SagaContextStatus @default(PENDING)
  currentStep   Int               @default(0)
  rawData       Json
  processData   Json              @default("{}")
  logs          String[]          @default([])
  error         String?
  retryCount    Int               @default(0)
  version       Int               @default(0)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@unique([sagaName, rawDataHash])
  @@unique([sagaName, externalId])
  @@index([status, updatedAt])
  @@map("saga_contexts")
}

enum OutboxMessageStatus {
  PENDING
  PROCESSED
  FAILED
}

model OutboxMessage {
  id            String              @id @default(uuid())
  aggregateType String
  aggregateId   String
  eventType     String
  payload       Json
  status        OutboxMessageStatus @default(PENDING)
  retryCount    Int                 @default(0)
  createdAt     DateTime            @default(now())
  processedAt   DateTime?

  @@index([status, createdAt])
  @@map("outbox_messages")
}
